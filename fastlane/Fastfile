default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_content = ENV["ASC_KEY_CONTENT"]

    # Token for the upload step (no Apple ID 2FA needed).
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: false
    )

    # gym has no api_key option, so authenticate xcodebuild for automatic signing
    # by writing the key to a file and passing -authenticationKey* flags directly
    # to both the archive (xcargs) and export (export_xcargs). fastlane runs lanes
    # from inside fastlane/, so use absolute temp paths.
    require "tmpdir"
    key_path = File.join(Dir.tmpdir, "asc_api_key.p8")
    File.write(key_path, key_content)
    auth = "-authenticationKeyPath #{key_path} " \
           "-authenticationKeyID #{key_id} " \
           "-authenticationKeyIssuerID #{issuer_id} " \
           "-allowProvisioningUpdates"

    # Explicit export options so the export step uses automatic (cloud) signing
    # instead of demanding a manual provisioning-profile mapping. A verbatim plist
    # is honored by gym as-is, unlike the hash form which gym merges with its own
    # (manual) detection.
    export_plist = File.join(Dir.tmpdir, "ExportOptions.plist")
    File.write(export_plist, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store</string>
        <key>signingStyle</key>
        <string>automatic</string>
        <key>teamID</key>
        <string>YG7C25J24J</string>
      </dict>
      </plist>
    PLIST

    # Unique, monotonically increasing build number per CI run so every upload
    # is accepted by TestFlight without manual version bumps.
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"

    build_app(
      project: "SipCheck.xcodeproj",
      scheme: "SipCheck",
      configuration: "Release",
      clean: true,
      output_directory: "build",
      output_name: "SipCheck.ipa",
      xcargs: "#{auth} DEVELOPMENT_TEAM=YG7C25J24J CURRENT_PROJECT_VERSION=#{build_number}",
      # gym auto-injects the API-key auth flags into the export step (from
      # app_store_connect_api_key), so only add -allowProvisioningUpdates here.
      # Passing the auth flags again duplicates them and xcodebuild exits 64.
      export_xcargs: "-allowProvisioningUpdates",
      export_options: export_plist
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
