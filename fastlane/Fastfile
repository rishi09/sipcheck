default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    # Authenticate with the App Store Connect API key (no Apple ID 2FA needed).
    # fastlane reuses this key for both provisioning updates and the upload.
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    # Unique, monotonically increasing build number per CI run so every upload
    # is accepted by TestFlight without manual version bumps.
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"

    build_app(
      project: "SipCheck.xcodeproj",
      scheme: "SipCheck",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "SipCheck.ipa",
      # Passing api_key here makes gym forward -authenticationKeyPath/ID/IssuerID to
      # the archive xcodebuild so automatic signing can create the distribution
      # profile. Without it the archive runs with no Apple credentials ("No Accounts").
      api_key: api_key,
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=YG7C25J24J CURRENT_PROJECT_VERSION=#{build_number}"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
