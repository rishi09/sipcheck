default_platform(:ios)

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_content = ENV["ASC_KEY_CONTENT"]

    # Token for the upload step (no Apple ID 2FA needed).
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: false
    )

    # gym has no api_key option, so authenticate xcodebuild for automatic signing
    # by writing the key to a file and passing -authenticationKey* flags directly
    # to both the archive (xcargs) and export (export_xcargs) steps. Without this
    # the archive runs with no Apple credentials ("No Accounts").
    key_path = File.absolute_path("fastlane/asc_api_key.p8")
    File.write(key_path, key_content)
    auth = "-authenticationKeyPath #{key_path} " \
           "-authenticationKeyID #{key_id} " \
           "-authenticationKeyIssuerID #{issuer_id} " \
           "-allowProvisioningUpdates"

    # Unique, monotonically increasing build number per CI run so every upload
    # is accepted by TestFlight without manual version bumps.
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"

    build_app(
      project: "SipCheck.xcodeproj",
      scheme: "SipCheck",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "SipCheck.ipa",
      xcargs: "#{auth} DEVELOPMENT_TEAM=YG7C25J24J CURRENT_PROJECT_VERSION=#{build_number}",
      export_xcargs: auth
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
