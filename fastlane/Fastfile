require "spaceship"
require "openssl"
require "base64"
require "tmpdir"
require "fileutils"

default_platform(:ios)

APP_IDENTIFIER = "com.rishishah.sipcheck"
TEAM_ID = "YG7C25J24J"
CI_CERT_NAME = "SipCheck CI Distribution"

platform :ios do
  desc "Build and upload to TestFlight with a self-provisioned distribution certificate"
  lane :beta do
    key_id = ENV["ASC_KEY_ID"]
    issuer_id = ENV["ASC_ISSUER_ID"]
    key_content = ENV["ASC_KEY_CONTENT"]

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: false
    )

    # ----- Authenticate spaceship for direct Developer Portal API calls -----
    token = Spaceship::ConnectAPI::Token.create(key_id: key_id, issuer_id: issuer_id, key: key_content)
    Spaceship::ConnectAPI.token = token

    # ----- Self-provision an Apple Distribution certificate -----
    # The App Manager key can't use cloud-managed distribution signing, but it may
    # be allowed to create a regular distribution certificate (where WE hold the
    # private key). Generate the key + CSR locally and ask the portal to issue it.
    # Revoke any prior CI-created cert first (its private key is gone each run, so
    # it can't be reused and would otherwise consume the account's cert quota).
    begin
      Spaceship::ConnectAPI::Certificate.all.each do |c|
        name = (c.respond_to?(:display_name) && c.display_name) || (c.respond_to?(:name) && c.name)
        if name == CI_CERT_NAME
          UI.message("Revoking stale CI cert #{c.id}")
          c.delete!
        end
      end
    rescue => e
      UI.important("Could not enumerate/revoke existing certs (continuing): #{e.message}")
    end

    priv_key = OpenSSL::PKey::RSA.new(2048)
    csr = OpenSSL::X509::Request.new
    csr.version = 0
    csr.subject = OpenSSL::X509::Name.new([["CN", CI_CERT_NAME, OpenSSL::ASN1::UTF8STRING]])
    csr.public_key = priv_key.public_key
    csr.sign(priv_key, OpenSSL::Digest::SHA256.new)

    cert = Spaceship::ConnectAPI::Certificate.create(
      certificate_type: "IOS_DISTRIBUTION",
      csr_content: csr.to_pem
    )
    x509 = OpenSSL::X509::Certificate.new(Base64.decode64(cert.certificate_content))

    p12_path = File.join(Dir.tmpdir, "sipcheck_dist.p12")
    File.binwrite(p12_path, OpenSSL::PKCS12.create("ci", CI_CERT_NAME, priv_key, x509).to_der)

    # ----- Install into a dedicated keychain -----
    keychain = "ci.keychain"
    create_keychain(
      name: keychain, password: "ci",
      default_keychain: true, unlock: true, timeout: 3600, lock_when_sleeps: false
    )
    import_certificate(
      certificate_path: p12_path, certificate_password: "ci",
      keychain_name: keychain, keychain_password: "ci"
    )

    # ----- App Store provisioning profile, created directly and tied to our cert -----
    # sigh can't discover the freshly-made cert, so build the profile via the API
    # ourselves, referencing the certificate id we just created.
    profile_name = "SipCheck CI AppStore"
    begin
      Spaceship::ConnectAPI::Profile.all(includes: "bundleId").each do |p|
        p.delete! if p.name == profile_name
      end
    rescue => e
      UI.important("Could not clean old CI profiles (continuing): #{e.message}")
    end

    bundle = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_IDENTIFIER }
    UI.user_error!("Bundle ID #{APP_IDENTIFIER} not found on the portal") if bundle.nil?

    profile = Spaceship::ConnectAPI::Profile.create(
      name: profile_name,
      profile_type: "IOS_APP_STORE",
      bundle_id_id: bundle.id,
      certificate_ids: [cert.id],
      device_ids: []
    )

    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profiles_dir)
    profile_path = File.join(profiles_dir, "#{profile.uuid}.mobileprovision")
    File.binwrite(profile_path, Base64.decode64(profile.profile_content))

    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"

    build_app(
      project: "SipCheck.xcodeproj",
      scheme: "SipCheck",
      configuration: "Release",
      clean: true,
      output_directory: "build",
      output_name: "SipCheck.ipa",
      export_method: "app-store",
      codesigning_identity: "iPhone Distribution",
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CURRENT_PROJECT_VERSION=#{build_number} " \
              "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
